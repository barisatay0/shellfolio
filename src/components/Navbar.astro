---
import { Terminal, Database, Cpu, User } from "lucide-astro";
import { CONFIG } from "../data/config";

const currentPath = Astro.url.pathname;

const links = [
    { path: "/", label: "~/dashboard", icon: User },
    { path: "/projects", label: "~/projects_db", icon: Database },
    { path: "/terminal", label: "~/bin/bash", icon: Terminal },
];
---

<nav
    class="w-full md:w-64 h-auto md:h-full bg-[#0a0a0a] border-b md:border-b-0 md:border-r border-slate-800/80 flex flex-col z-20 shrink-0"
>
    <div class="p-6 border-b border-slate-800/80 hidden md:block">
        <div class="flex items-center gap-2 text-green-500 font-bold mb-1">
            <Cpu size={20} />
            <span>{CONFIG.developer.alias}</span>
        </div>
        <p class="text-[10px] text-slate-300 tracking-widest uppercase">
            Kernel Access
        </p>
    </div>

    <ul
        class="flex-1 overflow-y-auto p-4 space-y-2 flex flex-row md:flex-col justify-around md:justify-start"
    >
        {
            links.map((link) => {
                const Icon = link.icon;
                // Aktif link kontrolü
                const isActive =
                    currentPath === link.path ||
                    currentPath === link.path + "/";

                return (
                    <li>
                        <a
                            href={link.path}
                            aria-label={`maps to ${link.label}`}
                            class={`flex items-center gap-3 px-4 py-3 rounded-md text-sm transition-all duration-200 ${
                                isActive
                                    ? "bg-green-500/10 text-green-300 border border-green-500/30 shadow-[0_0_15px_rgba(34,197,94,0.05)]"
                                    : "text-slate-300 hover:bg-slate-900 hover:text-slate-300"
                            }`}
                            aria-current={isActive ? "page" : undefined}
                        >
                            <Icon size={18} />
                            <span class="hidden md:inline">{link.label}</span>
                        </a>
                    </li>
                );
            })
        }
    </ul>
</nav>
