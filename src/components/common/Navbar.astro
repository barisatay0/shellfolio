---
import { Database, Briefcase, Code, GraduationCap, Globe, UserCircle } from "lucide-astro";
import { siteConfig } from "../../config/site";
import {
    getLangFromUrl,
    useTranslations,
    getRouteWithLang,
} from "../../i18n/utils";
import { ui, defaultLang } from "../../i18n/ui";

const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links: {
    path: string;
    key: keyof (typeof ui)[typeof defaultLang];
    icon: any;
}[] = [
    { path: "", key: "nav.dashboard", icon: UserCircle },
    { path: "experience", key: "nav.experience", icon: Briefcase },
    { path: "projects", key: "nav.projects", icon: Database },
    { path: "skills", key: "nav.skills", icon: Code },
    { path: "education", key: "nav.education", icon: GraduationCap },
];
---

<nav
    class="w-full md:w-64 h-auto md:h-full bg-white/[0.01] border-b md:border-b-0 md:border-r border-white/5 backdrop-blur-xl flex flex-col z-20 shrink-0 shadow-2xl relative"
>
    <!-- Top profile area -->
    <div class="p-8 border-b border-white/5 hidden md:flex flex-col items-center text-center">
        <div class="w-20 h-20 rounded-full border-2 border-green-500/20 p-1 mb-4 relative group">
            <div class="absolute inset-0 bg-green-500/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <img 
                src={siteConfig.developer.avatar} 
                alt={siteConfig.developer.name} 
                class="w-full h-full rounded-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500"
            />
        </div>
        <h2 class="text-white font-bold text-lg">{siteConfig.developer.name}</h2>
        <p class="text-green-400 text-xs font-medium uppercase tracking-wider mt-1">{siteConfig.developer.role[lang as "en" | "tr"]}</p>
    </div>

    <!-- Navigation links -->
    <ul class="flex-1 overflow-y-auto p-4 space-y-1 flex flex-row md:flex-col justify-around md:justify-start custom-scrollbar">
        {
            links.map((link) => {
                const Icon = link.icon;
                const linkPath = link.path === "" ? `/${lang}` : `/${lang}/${link.path}`;
                const isActive = currentPath === linkPath || currentPath === linkPath + "/";

                return (
                    <li>
                        <a
                            href={linkPath}
                            aria-label={t(link.key)}
                            class={`flex items-center gap-3 px-4 py-3 md:py-3.5 rounded-xl text-sm transition-all duration-300 relative group overflow-hidden ${
                                isActive
                                    ? "text-white bg-white/[0.05] border border-white/[0.08]"
                                    : "text-slate-400 hover:text-white hover:bg-white/[0.02]"
                            }`}
                        >
                            {isActive && (
                                <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-1/2 bg-green-500 rounded-r-full shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
                            )}
                            <Icon size={18} class={`transition-transform duration-300 ${isActive ? "text-green-400 scale-110" : "group-hover:scale-110"}`} />
                            <span class="hidden md:inline font-medium">{t(link.key)}</span>
                        </a>
                    </li>
                );
            })
        }
    </ul>

    <!-- Bottom actions -->
    <div class="p-4 md:p-6 border-t border-white/5 mt-0 md:mt-auto flex items-center justify-center md:justify-start bg-black/20">
        <div class="flex items-center gap-3 text-xs font-medium w-full justify-center md:justify-between">
            <Globe size={16} class="text-slate-500 hidden md:block" />
            <div class="flex gap-1 bg-white/[0.03] p-1 rounded-lg border border-white/5">
                <a
                    href={getRouteWithLang(Astro.url, "en")}
                    class={`px-3 py-1.5 rounded-md transition-all duration-300 ${lang === "en" ? "bg-white/10 text-white shadow-sm" : "text-slate-500 hover:text-slate-300"}`}
                >
                    EN
                </a>
                <a
                    href={getRouteWithLang(Astro.url, "tr")}
                    class={`px-3 py-1.5 rounded-md transition-all duration-300 ${lang === "tr" ? "bg-white/10 text-white shadow-sm" : "text-slate-500 hover:text-slate-300"}`}
                >
                    TR
                </a>
            </div>
        </div>
    </div>
</nav>
