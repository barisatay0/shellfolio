---
import { Terminal, Database, Cpu, User, Globe, Briefcase } from "lucide-astro";
import { siteConfig } from "../../config/site";
import {
    getLangFromUrl,
    useTranslations,
    getRouteWithLang,
} from "../../i18n/utils";
import { ui, defaultLang } from "../../i18n/ui";

const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links: {
    path: string;
    key: keyof (typeof ui)[typeof defaultLang];
    icon: any;
}[] = [
    { path: "", key: "nav.dashboard", icon: User },
    { path: "experience", key: "nav.experience", icon: Briefcase },
    { path: "projects", key: "nav.projects", icon: Database },
    { path: "terminal", key: "nav.terminal", icon: Terminal },
];
---

<nav
    class="w-full md:w-64 h-auto md:h-full bg-[#0a0a0a] border-b md:border-b-0 md:border-r border-slate-800/80 flex flex-col z-20 shrink-0"
>
    <div class="p-6 border-b border-slate-800/80 hidden md:block">
        <div class="flex items-center gap-2 text-green-500 font-bold mb-1">
            <Cpu size={20} />
            <span>{siteConfig.developer.alias}</span>
        </div>
        <p class="text-[10px] text-slate-300 tracking-widest uppercase">
            {t("nav.kernelAccess")}
        </p>
    </div>

    <ul
        class="flex-1 overflow-y-auto p-4 space-y-2 flex flex-row md:flex-col justify-around md:justify-start"
    >
        {
            links.map((link) => {
                const Icon = link.icon;

                const linkPath =
                    link.path === "" ? `/${lang}` : `/${lang}/${link.path}`;

                const isActive =
                    currentPath === linkPath || currentPath === linkPath + "/";

                const translatedText = t(link.key);

                return (
                    <li>
                        <a
                            href={linkPath}
                            aria-label={translatedText}
                            class={`flex items-center gap-3 px-4 py-3 rounded-md text-sm transition-all duration-200 ${
                                isActive
                                    ? "bg-green-500/10 text-green-300 border border-green-500/30 shadow-[0_0_15px_rgba(34,197,94,0.05)]"
                                    : "text-slate-300 hover:bg-slate-900 hover:text-slate-300"
                            }`}
                        >
                            <Icon size={18} />
                            <span class="hidden md:inline">{t(link.key)}</span>
                        </a>
                    </li>
                );
            })
        }
    </ul>

    <div
        class="p-2 md:p-4 border-l md:border-l-0 md:border-t border-slate-800/80 mt-0 md:mt-auto flex items-center justify-center md:justify-start"
    >
        <div class="flex items-center gap-2 text-xs font-mono">
            <Globe size={14} class="text-slate-400 hidden md:block" />
            <a
                href={getRouteWithLang(Astro.url, "en")}
                aria-label="Switch to English"
                class={`px-2 py-1 rounded transition-colors ${lang === "en" ? "bg-green-500/20 text-green-400 border border-green-500/30 font-bold" : "text-slate-400 hover:text-slate-300"}`}
            >
                EN
            </a>
            <span class="text-slate-800 font-bold">|</span>
            <a
                href={getRouteWithLang(Astro.url, "tr")}
                aria-label="Türkçe diline geç"
                class={`px-2 py-1 rounded transition-colors ${lang === "tr" ? "bg-green-500/20 text-green-400 border border-green-500/30 font-bold" : "text-slate-400 hover:text-slate-300"}`}
            >
                TR
            </a>
        </div>
    </div>
</nav>
