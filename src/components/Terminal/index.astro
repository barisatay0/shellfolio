---
import { CONFIG } from "../../data/config";

const configJson = JSON.stringify(CONFIG);
---

<sys-terminal
    data-config={configJson}
    class="flex h-135 bg-[#0A0A0A] border border-slate-800 rounded-lg shadow-2xl overflow-hidden font-mono text-sm flex-col w-full"
>
    <header
        class="bg-[#050505] border-b border-slate-800/80 p-2 flex items-center gap-2 shrink-0 select-none"
    >
        <div class="flex gap-1.5 ml-1">
            <div
                class="w-3 h-3 rounded-full bg-red-500/80 hover:bg-red-500 transition-colors"
            >
            </div>
            <div
                class="w-3 h-3 rounded-full bg-yellow-500/80 hover:bg-yellow-500 transition-colors"
            >
            </div>
            <div
                class="w-3 h-3 rounded-full bg-green-500/80 hover:bg-green-500 transition-colors"
            >
            </div>
        </div>
        <span class="ml-2 text-[10px] text-slate-300 tracking-widest uppercase"
            >root@{CONFIG.developer.alias} ~ /bin/bash</span
        >
    </header>

    <main
        class="flex-1 overflow-y-auto p-4 text-slate-300 cursor-text scroll-smooth"
        id="terminal-scroll"
    >
        <div id="terminal-output" class="space-y-1 mb-2">
            <p class="text-green-500 font-bold">AmogOS v1.5.0 (tty1)</p>
            <p class="text-slate-300 mb-4">
                Type <span class="text-green-300">'help'</span> for a list of available
                commands.
            </p>
        </div>

        <form id="terminal-form" class="flex items-center">
            <label for="terminal-input" class="sr-only">Terminal Command</label>
            <span class="text-green-500 mr-2 font-bold" aria-hidden="true"
                >➜</span
            >
            <span class="text-blue-400 mr-2 font-bold" aria-hidden="true"
                >~</span
            >
            <input
                id="terminal-input"
                type="text"
                class="flex-1 bg-transparent border-none outline-none text-slate-300 caret-green-500 font-mono"
                autofocus
                autocomplete="off"
                spellcheck="false"
            />
        </form>
    </main>
</sys-terminal>

<script src="./terminal.ts"></script>
