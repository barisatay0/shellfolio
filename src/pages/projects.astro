---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Database, Search, Github } from "lucide-astro";
import { CONFIG } from "../data/config";
---

<BaseLayout title="Projects DB">
    <div class="space-y-6">
        <header
            class="flex flex-col sm:flex-row sm:items-center justify-between gap-4"
        >
            <div>
                <h1
                    class="text-xl text-white font-bold flex items-center gap-2"
                >
                    <Database class="text-blue-500" size={24} />
                    SELECT * FROM public.projects;
                </h1>
                <p class="text-xs text-slate-300 mt-1">
                    Connected to primary database instance.
                </p>
            </div>
            <div
                class="text-xs font-mono bg-[#0a0a0a] py-1.5 px-3 rounded border border-slate-800 text-green-300 flex items-center gap-2"
            >
                <Search size={14} class="text-slate-300" />
                Query returned {CONFIG.projects.length} rows
            </div>
        </header>

        <div
            class="bg-[#0a0a0a] border border-slate-800/80 rounded-lg overflow-x-auto shadow-2xl"
        >
            <table class="w-full text-left text-sm font-mono min-w-175">
                <thead
                    class="bg-slate-900/50 text-slate-300 border-b border-slate-800/80"
                >
                    <tr>
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >id</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >project_details</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >tech_stack</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >latency</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >status</th
                        >
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50 text-slate-300">
                    {
                        CONFIG.projects.map((proj) => (
                            <tr class="hover:bg-slate-800/30 transition-colors group">
                                <td class="p-4 text-slate-300 align-top pt-5">
                                    {proj.id}
                                </td>
                                <td class="p-4 align-top">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-bold text-blue-400 group-hover:text-blue-300 transition-colors">
                                            {proj.name}
                                        </span>
                                        {proj.url && (
                                            <a
                                                href={proj.url}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label={`${proj.name} GitHub repository`}
                                                class="text-slate-300 hover:text-white transition-colors"
                                                aria-label={`View ${proj.name} source code on GitHub`}
                                            >
                                                <Github size={14} />
                                            </a>
                                        )}
                                    </div>
                                    <p class="text-xs text-slate-300 max-w-sm leading-relaxed">
                                        {proj.description}
                                    </p>
                                </td>
                                <td class="p-4 align-top pt-5">
                                    <div class="flex gap-2 flex-wrap">
                                        {proj.stack.map((tech) => (
                                            <span class="text-[10px] bg-slate-900 px-2 py-0.5 rounded border border-slate-700 text-slate-300">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                </td>
                                <td class="p-4 text-slate-300 align-top pt-5">
                                    {proj.latency}
                                </td>
                                <td class="p-4 align-top pt-5">
                                    <span
                                        class={`text-[10px] px-2.5 py-1 rounded-full border tracking-wide ${
                                            proj.status === "PROD"
                                                ? "bg-green-500/10 text-green-300 border-green-500/20"
                                                : proj.status === "BETA"
                                                  ? "bg-yellow-500/10 text-yellow-400 border-yellow-500/20"
                                                  : "bg-red-500/10 text-red-400 border-red-500/20"
                                        }`}
                                    >
                                        {proj.status}
                                    </span>
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </div>
</BaseLayout>
