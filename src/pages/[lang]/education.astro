---
import Layout from "../../layouts/Layout.astro";
import { GraduationCap, Calendar, MapPin } from "lucide-astro";
import { educations } from "../../content/education";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "tr" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("nav.education")}>
    <div class="space-y-8">
        <header class="mb-12">
            <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                <GraduationCap class="text-green-500" size={28} />
                {t("nav.education")}
            </h1>
            <p class="text-slate-400">Academic background and qualifications</p>
        </header>

        <div class="grid grid-cols-1 gap-6">
            {educations.map((edu) => (
                <div class="glass-panel p-8 hover:border-green-500/30 transition-all duration-500 group relative overflow-hidden">
                    <div class="absolute -right-12 -top-12 w-32 h-32 bg-green-500/5 rounded-full blur-2xl group-hover:bg-green-500/10 transition-colors duration-500"></div>
                    
                    <div class="flex flex-col md:flex-row md:items-start justify-between gap-6 relative z-10">
                        <div class="flex items-start gap-6">
                            <div class="w-14 h-14 rounded-2xl bg-white/[0.03] border border-white/10 flex items-center justify-center text-slate-300 group-hover:text-green-400 group-hover:border-green-500/30 group-hover:bg-green-500/10 transition-all duration-500 shrink-0">
                                <GraduationCap size={28} />
                            </div>
                            
                            <div>
                                <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-green-400 transition-colors">
                                    {edu.school}
                                </h2>
                                <h3 class="text-lg text-slate-300 font-medium mb-4">
                                    {edu.degree} in {edu.field}
                                </h3>
                                
                                {edu.description && (
                                    <p class="text-slate-400 leading-relaxed max-w-2xl">
                                        {edu.description}
                                    </p>
                                )}
                            </div>
                        </div>
                        
                        <div class="flex flex-col gap-3 shrink-0 md:items-end">
                            <div class="flex items-center gap-2 text-sm text-green-400 bg-green-500/10 px-4 py-2 rounded-lg border border-green-500/20 font-medium">
                                <Calendar size={16} />
                                {edu.duration}
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>
