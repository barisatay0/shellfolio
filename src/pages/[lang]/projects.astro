---
import Layout from "../../layouts/Layout.astro";
import { Database, Github, ExternalLink } from "lucide-astro";
import { projects } from "../../content/projects";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { Image } from "astro:assets";

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "tr" } }];
}

const lang = getLangFromUrl(Astro.url);
const currentLang = lang as "en" | "tr";
const t = useTranslations(lang);

type BadgeType = "green" | "blue" | "gray";

const getBadgeStyle = (type: BadgeType) => {
    const base = "text-[10px] px-2.5 py-1 rounded-full border font-semibold tracking-wide uppercase";
    const colors = {
        green: "bg-green-500/10 text-green-400 border-green-500/20",
        blue: "bg-blue-500/10 text-blue-400 border-blue-500/20",
        gray: "bg-slate-500/10 text-slate-400 border-slate-500/20",
    };
    return `${base} ${colors[type]}`;
};

const resolveStatusColor = (status: string): BadgeType => {
    if (status === "DEVELOPMENT") return "green";
    if (status === "MAINTAINED") return "blue";
    return "gray";
};

const resolveVisibilityColor = (visibility: string): BadgeType => {
    return visibility === "PUBLIC" ? "green" : "blue";
};
---

<Layout title={t("page.projects.title")}>
    <div class="space-y-8">
        <header class="mb-8">
            <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                <Database class="text-green-500" size={28} />
                {t("page.projects.title")}
            </h1>
            <p class="text-slate-400">{t("page.projects.rows", projects.length)}</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {projects.map((proj) => (
                <div class="glass-panel p-6 sm:p-8 flex flex-col group hover:border-green-500/30 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_10px_40px_-10px_rgba(34,197,94,0.1)]">
                    <div class="flex justify-between items-start mb-6 gap-4">
                        <div class="flex items-center gap-4">
                            {proj.logo && (
                                <div class="w-14 h-14 rounded-xl bg-white/[0.03] border border-white/10 p-2 shrink-0 flex items-center justify-center group-hover:scale-110 group-hover:bg-white/[0.05] transition-all duration-300">
                                    <Image
                                        src={proj.logo}
                                        alt={`${proj.name} logo`}
                                        width={48}
                                        height={48}
                                        format="webp"
                                        quality={90}
                                        class="w-full h-full object-contain"
                                    />
                                </div>
                            )}
                            <div>
                                <h2 class="text-xl font-bold text-white mb-1 group-hover:text-green-400 transition-colors">
                                    {proj.name}
                                </h2>
                                <div class="flex items-center gap-2 text-xs text-slate-400">
                                    <span class="font-mono bg-white/[0.05] px-2 py-0.5 rounded border border-white/5">{proj.license}</span>
                                    <span>•</span>
                                    <span>{proj.year}</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-col gap-2 shrink-0 items-end">
                            <span class={getBadgeStyle(resolveStatusColor(proj.status))}>{proj.status}</span>
                            <span class={getBadgeStyle(resolveVisibilityColor(proj.visibility))}>{proj.visibility}</span>
                        </div>
                    </div>

                    <p class="text-sm text-slate-300 leading-relaxed mb-6 flex-1">
                        {proj.description[currentLang] || proj.description.en}
                    </p>

                    <div class="flex flex-wrap gap-2 mb-6">
                        {proj.stack.map((tech) => (
                            <span class="text-xs bg-green-500/5 text-green-300/80 px-2.5 py-1 rounded-md border border-green-500/10">
                                {tech}
                            </span>
                        ))}
                    </div>

                    {proj.images && proj.images.length > 0 && (
                        <div class="flex gap-3 mb-6 overflow-x-auto pb-2 custom-scrollbar">
                            {proj.images.map((img, index) => (
                                <a href={img.src} target="_blank" rel="noopener noreferrer" class="shrink-0 overflow-hidden rounded-lg border border-white/10 hover:border-green-500/50 transition-colors">
                                    <Image
                                        src={img}
                                        alt={`${proj.name} screenshot ${index + 1}`}
                                        width={240}
                                        height={135}
                                        format="webp"
                                        quality={80}
                                        class="h-20 w-auto object-cover hover:scale-105 transition-transform duration-500"
                                    />
                                </a>
                            ))}
                        </div>
                    )}

                    <div class="mt-auto pt-6 border-t border-white/5 flex gap-4">
                        {proj.github && (
                            <a href={proj.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-slate-300 hover:text-white transition-colors bg-white/[0.03] hover:bg-white/[0.08] px-4 py-2 rounded-lg border border-white/5">
                                <Github size={16} />
                                Repository
                            </a>
                        )}
                        {proj.url && (
                            <a href={proj.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-green-400 hover:text-green-300 transition-colors bg-green-500/10 hover:bg-green-500/20 px-4 py-2 rounded-lg border border-green-500/20">
                                <ExternalLink size={16} />
                                Live Demo
                            </a>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>
