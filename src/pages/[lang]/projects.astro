---
import Layout from "../../layouts/Layout.astro";
import { Database, Search, Github, ExternalLink } from "lucide-astro";
import { projects } from "../../content/projects";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { Image } from "astro:assets";
import PageHeader from "../../components/common/PageHeader.astro";

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "tr" } }];
}

const lang = getLangFromUrl(Astro.url);
const currentLang = lang as "en" | "tr";
const t = useTranslations(lang);

type BadgeType = "green" | "blue" | "gray";

const getBadgeStyle = (type: BadgeType) => {
    const base =
        "text-[10px] px-2 py-1 rounded-full border tracking-wide font-bold";
    const colors = {
        green: "bg-green-500/10 text-green-400 border-green-500/20",
        blue: "bg-blue-500/10 text-blue-400 border-blue-500/20",
        gray: "bg-slate-500/10 text-slate-400 border-slate-500/20",
    };
    return `${base} ${colors[type]}`;
};

const resolveStatusColor = (status: string): BadgeType => {
    if (status === "DEVELOPMENT") return "green";
    if (status === "MAINTAINED") return "blue";
    return "gray";
};

const resolveVisibilityColor = (visibility: string): BadgeType => {
    return visibility === "PUBLIC" ? "green" : "blue";
};
---

<Layout title={t("page.projects.title")}>
    <div class="space-y-6">
        <PageHeader
            title={t("page.projects.query")}
            subtitle={t("page.projects.subtitle")}
            countText={t("page.projects.rows", projects.length)}
        >
            <Database slot="icon" class="text-blue-500" size={24} />
        </PageHeader>
        <div
            class="bg-[#0a0a0a] border border-slate-800/80 rounded-lg shadow-2xl overflow-hidden"
        >
            <table class="w-full text-left text-sm font-mono block lg:table">
                <thead
                    class="hidden lg:table-header-group bg-slate-900/50 text-slate-300 border-b border-slate-800/80"
                >
                    <tr>
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >{t("table.id")}</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >{t("table.details")}</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >{t("table.stack")}</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >{t("table.visibility")}</th
                        >
                        <th
                            class="p-4 font-semibold uppercase tracking-wider text-xs"
                            >{t("table.status")}</th
                        >
                    </tr>
                </thead>
                <tbody
                    class="block lg:table-row-group divide-y divide-slate-800/50 text-slate-300"
                >
                    {
                        projects.map((proj) => (
                            <tr class="block lg:table-row hover:bg-slate-800/30 transition-colors group p-5 lg:p-0">
                                <td class="block lg:table-cell lg:p-4 align-top lg:pt-5 mb-3 lg:mb-0">
                                    <div class="flex items-center justify-between lg:block">
                                        <span class="text-green-500 lg:text-slate-300 font-bold lg:font-normal text-xs lg:text-sm">
                                            {proj.id}
                                        </span>
                                        <div class="lg:hidden flex gap-2">
                                            <span
                                                class={getBadgeStyle(
                                                    resolveVisibilityColor(
                                                        proj.visibility,
                                                    ),
                                                )}
                                            >
                                                {proj.visibility}
                                            </span>
                                            <span
                                                class={getBadgeStyle(
                                                    resolveStatusColor(
                                                        proj.status,
                                                    ),
                                                )}
                                            >
                                                {proj.status}
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mt-1 hidden lg:block">
                                        <span class="text-[10px] text-slate-400">
                                            {proj.year}
                                        </span>
                                    </div>
                                </td>

                                <td class="block lg:table-cell lg:p-4 align-top mb-4 lg:mb-0">
                                    <div class="flex items-start gap-3 lg:gap-4">
                                        {proj.logo && (
                                            <Image
                                                src={proj.logo}
                                                alt={`${proj.name} logo`}
                                                width={48}
                                                height={48}
                                                format="webp"
                                                quality={80}
                                                class="w-10 h-10 sm:w-12 sm:h-12 rounded bg-slate-900 border border-slate-700 object-contain p-1 shrink-0 mt-1"
                                            />
                                        )}

                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="font-bold text-blue-400 group-hover:text-blue-300 transition-colors text-base lg:text-sm">
                                                    {proj.name}
                                                </span>
                                                <span class="text-[10px] bg-slate-800/50 text-slate-400 px-1.5 py-0.5 rounded border border-slate-700/50">
                                                    {proj.license}
                                                </span>
                                                {proj.github && (
                                                    <a
                                                        href={proj.github}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        aria-label={`${proj.name} GitHub repository`}
                                                        class="text-slate-300 hover:text-white transition-colors ml-1 shrink-0"
                                                    >
                                                        <Github
                                                            size={16}
                                                            class="lg:w-4 lg:h-4"
                                                            aria-hidden="true"
                                                        />
                                                    </a>
                                                )}
                                                {proj.url && (
                                                    <a
                                                        href={proj.url}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        aria-label={`Visit ${proj.name} live site`}
                                                        class="text-slate-300 hover:text-blue-400 transition-colors shrink-0"
                                                    >
                                                        <ExternalLink
                                                            size={16}
                                                            class="lg:w-4 lg:h-4"
                                                            aria-hidden="true"
                                                        />
                                                    </a>
                                                )}
                                            </div>
                                            <p class="text-xs text-slate-400 lg:text-slate-300 leading-relaxed mb-2">
                                                {proj.description[
                                                    currentLang
                                                ] || proj.description.en}
                                            </p>

                                            {proj.images &&
                                                proj.images.length > 0 && (
                                                    <div class="flex gap-2 mt-3 overflow-x-auto pb-2 custom-scrollbar">
                                                        {proj.images.map(
                                                            (img, index) => (
                                                                <a
                                                                    href={
                                                                        img.src
                                                                    }
                                                                    target="_blank"
                                                                    rel="noopener noreferrer"
                                                                    class="shrink-0"
                                                                    aria-label={`View ${proj.name} screenshot ${index + 1}`}
                                                                >
                                                                    <Image
                                                                        src={
                                                                            img
                                                                        }
                                                                        alt={`${proj.name} screenshot ${index + 1}`}
                                                                        width={
                                                                            128
                                                                        }
                                                                        height={
                                                                            72
                                                                        }
                                                                        format="webp"
                                                                        quality={
                                                                            75
                                                                        }
                                                                        class="h-16 w-auto rounded border border-slate-700/50 object-cover hover:border-blue-400 transition-colors duration-200"
                                                                    />
                                                                </a>
                                                            ),
                                                        )}
                                                    </div>
                                                )}
                                        </div>
                                    </div>
                                </td>

                                <td class="block lg:table-cell lg:p-4 align-top lg:pt-5 mb-3 lg:mb-0">
                                    <div class="flex gap-2 flex-wrap">
                                        {proj.stack.map((tech) => (
                                            <span class="text-[10px] bg-slate-900 px-2 py-0.5 rounded border border-slate-700 text-slate-300">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                </td>

                                <td class="hidden lg:table-cell lg:p-4 align-top lg:pt-5 mb-2 lg:mb-0">
                                    <span
                                        class={getBadgeStyle(
                                            resolveVisibilityColor(
                                                proj.visibility,
                                            ),
                                        )}
                                    >
                                        {proj.visibility}
                                    </span>
                                </td>

                                <td class="hidden lg:table-cell p-4 align-top pt-5">
                                    <span
                                        class={getBadgeStyle(
                                            resolveStatusColor(proj.status),
                                        )}
                                    >
                                        {proj.status}
                                    </span>
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </div>
</Layout>
