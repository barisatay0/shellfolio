---
import Layout from "../../layouts/Layout.astro";
import { siteConfig } from "../../config/site";
import { skills } from "../../content/projects";
import { Terminal } from "lucide-astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { Image } from 'astro:assets';

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "tr" } }];
}

const lang = getLangFromUrl(Astro.url);
const currentLang = lang as "en" | "tr";
const t = useTranslations(lang);
---

<Layout title={t("dashboard.title")}>
    <div class="space-y-8">
        <section
            class="bg-slate-900/50 border border-slate-800/60 rounded-lg p-6 sm:p-8 relative overflow-hidden backdrop-blur-sm flex flex-col sm:flex-row gap-6 items-center sm:items-center text-center sm:text-left"
        >
            {
                siteConfig.developer.avatar && (
                    <div class="relative shrink-0 group">
                        <div class="absolute inset-0 bg-green-500/20 blur-xl rounded-full group-hover:bg-green-500/30 transition-all duration-300" />
                             <Image 
                                 src={siteConfig.developer.avatar} 
                                 alt="Developer Avatar" 
                                 width={96} 
                                 height={96}
                                 class="relative w-28 h-28 sm:w-24 sm:h-24 rounded-xl border border-slate-700 sm:border-green-500/50 object-cover shadow-[0_0_15px_rgba(34,197,94,0.1)] grayscale hover:grayscale-0 transition-all duration-300 z-10"
                             />
                        <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-green-500 border-2 border-slate-900 rounded-full animate-pulse z-20 shadow-[0_0_8px_rgba(34,197,94,0.8)]" />
                    </div>
                )
            }
            <div
                class="flex-1 w-full flex flex-col items-center sm:items-start"
            >
                <h1
                    class="text-2xl sm:text-3xl font-bold text-white mb-2 break-words"
                >
                    <span class="text-green-500"
                        >{t("dashboard.developer")}</span
                    >"{siteConfig.developer.name}";
                </h1>
                <p
                    class="text-sm sm:text-base text-slate-300 max-w-2xl leading-relaxed mb-6"
                >
                    {siteConfig.developer.bio[currentLang] || siteConfig.developer.bio.en}
                </p>

                <div
                    class="flex flex-wrap justify-center sm:justify-start gap-3 w-full"
                >
                    {
                        Object.entries(siteConfig.socials).map(
                            ([platform, url]) => (
                                <a
                                    href={url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-[10px] sm:text-xs uppercase tracking-widest text-slate-300 hover:text-green-300 border border-slate-800 hover:border-green-500/50 px-4 py-2 rounded transition-colors bg-slate-950"
                                >
                                    {platform}
                                </a>
                            ),
                        )
                    }
                </div>
            </div>
        </section>

        <section>
            <h2
                class="text-sm text-slate-300 mb-4 flex items-center gap-2 uppercase tracking-wider"
            >
                <Terminal size={16} />
                {t("dashboard.capabilities")}
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {
                    skills.map((skillGroup) => (
                        <div class="bg-slate-950 border border-slate-800/60 p-4 rounded-lg">
                            <h3 class="text-green-500 text-xs font-bold mb-3 uppercase">
                                {skillGroup.category}
                            </h3>
                            <ul class="flex flex-wrap gap-2">
                                {skillGroup.items.map((item) => (
                                    <li class="bg-slate-900 border border-slate-800 px-2 py-1 text-xs rounded text-slate-300">
                                        {item}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </section>
    </div>
</Layout>
