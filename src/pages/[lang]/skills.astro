---
import Layout from "../../layouts/Layout.astro";
import { Code2, Server, Wrench, Globe, Database } from "lucide-astro";
import { skills } from "../../content/projects";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "tr" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getIconForCategory = (category: string) => {
    switch (category) {
        case "Languages": return Code2;
        case "Frontend": return Globe;
        case "Backend": return Server;
        case "Tools": return Wrench;
        default: return Database;
    }
};
---

<Layout title={t("nav.skills")}>
    <div class="space-y-8">
        <header class="mb-12">
            <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                <Code2 class="text-green-500" size={28} />
                {t("nav.skills")}
            </h1>
            <p class="text-slate-400">Technical proficiencies and tools</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {skills.map((skillGroup) => {
                const Icon = getIconForCategory(skillGroup.category);
                return (
                    <div class="glass-panel p-8 hover:border-green-500/30 transition-all duration-500 group">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="w-12 h-12 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center text-green-400 group-hover:scale-110 group-hover:bg-green-500/20 transition-all duration-300">
                                <Icon size={24} />
                            </div>
                            <h2 class="text-xl font-bold text-white group-hover:text-green-400 transition-colors">
                                {skillGroup.category}
                            </h2>
                        </div>
                        
                        <div class="flex flex-wrap gap-3">
                            {skillGroup.items.map((item) => (
                                <span class="bg-white/5 hover:bg-green-500/10 text-slate-300 hover:text-green-400 px-4 py-2 rounded-lg border border-white/10 hover:border-green-500/30 transition-all cursor-default">
                                    {item}
                                </span>
                            ))}
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</Layout>
