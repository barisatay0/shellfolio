---
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import Navbar from "../components/common/Navbar.astro";
import { siteConfig } from "../config/site";
import "../styles/global.css";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
    title: string;
    description?: string;
}

const lang = getLangFromUrl(Astro.url);
const currentLang = lang as "en" | "tr";
const t = useTranslations(lang);

const defaultDescription =
    siteConfig.developer.bio[currentLang] || siteConfig.developer.bio.en;

const { title, description = defaultDescription } = Astro.props;
---

<!doctype html>
<html
    lang={lang}
    class="h-full bg-black text-slate-300 font-mono antialiased selection:bg-green-900 selection:text-white"
>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <title>{title} | {siteConfig.developer.alias}</title>
        <ClientRouter />
    </head>
    <body
        class="h-full md:h-dvh w-full flex flex-col md:flex-row overflow-hidden bg-black"
    >
        <Navbar />

        <main
            class="flex-1 flex flex-col relative bg-[#050505] min-h-0 overflow-hidden"
        >
            <header
                class="h-12 border-b border-slate-800 bg-black flex items-center px-6 text-xs text-white justify-between shrink-0 z-20"
            >
                <div class="flex gap-4">
                    <span class="hidden sm:inline font-bold text-slate-100"
                        >{t("layout.user")}</span
                    >
                    <span class="text-slate-100"
                        >{t("layout.sys", siteConfig.developer.system)}</span
                    >
                </div>
                <div class="flex items-center gap-2">
                    <span>{t("layout.status")}</span>
                    <strong
                        class="text-[#4ade80] animate-pulse font-bold tracking-wider"
                        >{t("layout.online")}</strong
                    >
                </div>
            </header>

            <div
                class="absolute inset-0 pointer-events-none opacity-[0.03] bg-[linear-gradient(#fff_1px,transparent_1px),linear-gradient(90deg,#fff_1px,transparent_1px)] bg-size-[40px_40px] z-0"
            >
            </div>

            <div
                class="flex-1 overflow-y-auto p-4 md:p-8 relative z-10 custom-scrollbar"
            >
                <div
                    class="max-w-5xl mx-auto pb-24 animate-in fade-in slide-in-from-bottom-4 duration-500"
                >
                    <slot />
                </div>
            </div>
        </main>

        <SpeedInsights />
        <Analytics />
    </body>
</html>
